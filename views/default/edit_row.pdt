<?php /** @var View $this **/ ?>

<?php
        $this->Widget->clear();
        $this->Widget->setLinkButtons([
            ['name' => $this->_('Nominet.back_to_manage', true), 'icon' => 'bi bi-arrow-left me-1', 'attributes' => ['href' => $this->base_uri . 'settings/company/modules/manage/' . $module->id]]
        ]);
        $this->Widget->create($this->_('Nominet.edit_row.box_title', true));
        ?>
<div>
    <?php

            $this->Form->create(null, ['class' => 'disable-on-submit']);
            ?>

    <div class="mb-3">
        <label for="username" class="form-label">
            <?php $this->_('Nominet.row_meta.username');?>
        </label>
        <?php
                $this->Form->fieldText('username', ($vars->username ?? null), ['id' => 'username', 'class' => 'form-control']);
                ?>
    </div>

    <div class="mb-3">
        <label for="password" class="form-label">
            <?php $this->_('Nominet.row_meta.password');?>
        </label>
        <?php
                $this->Form->fieldText('password', ($vars->password ?? null), ['id' => 'password', 'class' => 'form-control']);
                ?>
    </div>

    <div class="mb-3">
        <div class="form-check">
            <?php

                    $this->Form->fieldCheckbox('secure', 'true', ($vars->secure ?? 'false') == 'true', ['id' => 'secure', 'class' => 'form-check-input']);
                    ?>
            <label for="secure" class="form-check-label">
                <?php $this->_('Nominet.row_meta.secure');?>
            </label>
        </div>
    </div>

    <div class="mb-3">
        <div class="form-check">
            <?php

                    $this->Form->fieldCheckbox('sandbox', 'true', ($vars->sandbox ?? 'false') == 'true', ['id' => 'sandbox', 'class' => 'form-check-input']);
                    ?>
            <label for="sandbox" class="form-check-label">
                <?php $this->_('Nominet.row_meta.sandbox');?>
            </label>
        </div>
    </div>

    <?php $this->Widget->footer(); ?>
    <div class="d-flex justify-content-end">
        <?php

                $this->Form->fieldSubmit('save', $this->_('Nominet.edit_row.edit_btn', true), ['class' => 'btn btn-primary']);
                ?>
    </div>

    <?php
            $this->Form->end();
            ?>
</div>
        <?php
        $this->Widget->end();
        ?>
