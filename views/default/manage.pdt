<?php /** @var View $this **/ ?>

<?php
$link_buttons = [
    [
        'name' => $this->_('Nominet.add_module_row', true),
        'attributes' => ['href' => $this->base_uri . 'settings/company/modules/addrow/' . $module->id],
    ],
    [
        'name' => $this->_('Nominet.add_module_group', true),
        'attributes' => ['href' => $this->base_uri . 'settings/company/modules/addgroup/' . $module->id],
    ],
];

$tabs = [
    [
        'name' => $this->_('Nominet.manage.tab_rows', true),
        'current' => true,
        'attributes' => [
            'class' => 'rows',
            'href' => '#tab_rows',
            'id' => 'rows_tab',
            'data-bs-toggle' => 'tab',
            'role' => 'tab'
        ]
    ],
    [
        'name' => $this->_('Nominet.manage.tab_groups', true),
        'current' => false,
        'attributes' => [
            'class' => 'groups',
            'href' => '#tab_groups',
            'id' => 'groups_tab',
            'data-bs-toggle' => 'tab',
            'role' => 'tab'
        ]
    ]
];

$this->Widget->clear();
$this->Widget->setLinkButtons($link_buttons);
$this->Widget->setTabs($tabs);
$this->Widget->setBodyWrapper(false);

$this->Widget->create(
    $this->_(
        'AdminCompanyModules.manage.boxtitle_manage',
        true,
        isset($module->name) ? $this->Html->safe($module->name, true) : null,
    ),
    ['id' => 'manage_nominet'],
);
?>

<div class="tab-content">
<div class="tab-pane fade show active" id="tab_rows" role="tabpanel">
        <?php
        $num_rows = count($module->rows ?? []);
        if ($num_rows > 0) { ?>
<table class="table">
    <tr class="heading_row">
        <td><span><?php $this->_('Nominet.manage.module_rows_heading.username'); ?></span></td>
        <td class="last"><span><?php $this->_('Nominet.manage.module_rows_heading.options'); ?></span></td>
    </tr>
            <?php for ($i = 0; $i < $num_rows; $i++) { ?>
    <tr<?php echo $i % 2 == 1 ? ' class="odd_row"' : ''; ?>>
        <td><?php echo isset($module->rows[$i]->meta->username)
            ? $this->Html->safe($module->rows[$i]->meta->username)
            : null; ?></td>
        <td class="last">
            <a href="<?php echo $this->Html->safe(
                $this->base_uri .
                    'settings/company/modules/editrow/' .
                    (isset($module->id) ? $module->id : null) .
                    '/' .
                    (isset($module->rows[$i]->id) ? $module->rows[$i]->id : null) .
                    '/',
            ); ?>" class="btn btn-sm btn-outline-secondary" title="<?php $this->_(
    'Nominet.manage.module_rows.edit',
); ?>">
                <i class="bi bi-pencil"></i>
            </a>
            <?php
            $this->Form->create($this->base_uri . 'settings/company/modules/deleterow/', ['class' => 'd-inline']);
            $this->Form->fieldHidden('id', isset($module->id) ? $module->id : null);
            $this->Form->fieldHidden('row_id', isset($module->rows[$i]->id) ? $module->rows[$i]->id : null);
            ?>
            <button type="button" class="btn btn-sm btn-outline-danger modal-confirm-delete"
                data-confirm-message="<?php echo $this->Html->safe(
                    $this->_('Nominet.manage.module_rows.confirm_delete', true),
                ); ?>"
                title="<?php $this->_('Nominet.manage.module_rows.delete'); ?>">
                <i class="bi bi-trash"></i>
            </button>
            <?php $this->Form->end(); ?>
        </td>
        </tr>
            <?php } ?>
</table>
            <?php } else { ?>
<div class="card-body text-center text-muted py-5">
    <i class="bi bi-globe" style="font-size: 3rem; opacity: 0.3;"></i>
    <p class="mt-3 mb-0"><?php $this->_('Nominet.manage.module_rows_no_results'); ?></p>
</div>
            <?php }
        ?>

</div>
<div class="tab-pane fade" id="tab_groups" role="tabpanel">
            <?php
            $num_rows = count(isset($module->groups) ? $module->groups : []);
            if ($num_rows > 0) { ?>
<table class="table">
    <tr class="heading_row">
        <td><span><?php $this->_('Nominet.manage.module_groups_heading.name'); ?></span></td>
        <td><span><?php $this->_('Nominet.manage.module_groups_heading.module_rows'); ?></span></td>
        <td class="last"><span><?php $this->_('Nominet.manage.module_groups_heading.options'); ?></span></td>
    </tr>
            <?php for ($i = 0; $i < $num_rows; $i++) { ?>
    <tr<?php echo $i % 2 == 1 ? ' class="odd_row"' : ''; ?>>
        <td><?php echo isset($module->groups[$i]->name) ? $this->Html->safe($module->groups[$i]->name) : null; ?></td>
        <td><?php echo count(isset($module->groups[$i]->rows) ? $module->groups[$i]->rows : []); ?></td>
        <td>
            <a href="<?php echo $this->Html->safe(
                $this->base_uri .
                    'settings/company/modules/editgroup/' .
                    (isset($module->id) ? $module->id : null) .
                    '/' .
                    (isset($module->groups[$i]->id) ? $module->groups[$i]->id : null) .
                    '/',
            ); ?>" class="btn btn-sm btn-outline-secondary" title="<?php $this->_(
    'Nominet.manage.module_groups.edit',
); ?>">
                <i class="bi bi-pencil"></i>
            </a>
            <?php
            $this->Form->create($this->base_uri . 'settings/company/modules/deletegroup/', ['class' => 'd-inline']);
            $this->Form->fieldHidden('id', isset($module->id) ? $module->id : null);
            $this->Form->fieldHidden('group_id', isset($module->groups[$i]->id) ? $module->groups[$i]->id : null);
            ?>
            <button type="button" class="btn btn-sm btn-outline-danger modal-confirm-delete"
                data-confirm-message="<?php echo $this->Html->safe(
                    $this->_('Nominet.manage.module_groups.confirm_delete', true),
                ); ?>"
                title="<?php $this->_('Nominet.manage.module_groups.delete'); ?>">
                <i class="bi bi-trash"></i>
            </button>
            <?php $this->Form->end(); ?>
        </td>
        </tr>
            <?php } ?>
</table>
            <?php } else { ?>
<div class="card-body text-center text-muted py-5">
    <i class="bi bi-collection" style="font-size: 3rem; opacity: 0.3;"></i>
    <p class="mt-3 mb-0"><?php $this->_('Nominet.manage.module_groups.no_results'); ?></p>
</div>
            <?php }
?>
</div>
</div>

<?php $this->Widget->end(); ?>
